# === Manhaji Teacher Portal ===
# Copy this to .env and fill in your values

# Backend base URL. In dev, Vite proxies /api → localhost:8080
# so you do NOT need to change this unless your backend runs elsewhere.
VITE_API_URL=/api

# If your Spring Boot server is on a different port or host:
# VITE_API_URL=http://localhost:8080/api
